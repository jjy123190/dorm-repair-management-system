<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.scau.dormrepair.mapper.RepairRequestImageMapper">

    <insert id="batchInsert">
        INSERT INTO repair_request_images (
            repair_request_id,
            image_url,
            sort_no
        ) VALUES
        <foreach collection="imageUrls" item="imageUrl" index="index" separator=",">
            (
                #{repairRequestId},
                #{imageUrl},
                ${index + 1}
            )
        </foreach>
    </insert>
</mapper>
