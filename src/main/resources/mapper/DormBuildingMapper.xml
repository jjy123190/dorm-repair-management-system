<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.scau.dormrepair.mapper.DormBuildingMapper">

    <select id="selectDistinctAreas" resultType="string">
        SELECT campus_name
        FROM dorm_buildings
        GROUP BY campus_name
        ORDER BY MIN(id) ASC
    </select>

    <select id="selectByArea" parameterType="string" resultType="com.scau.dormrepair.domain.entity.DormBuilding">
        SELECT
            id,
            campus_name,
            building_no,
            building_name,
            created_at,
            updated_at
        FROM dorm_buildings
        WHERE campus_name = #{campusName}
        ORDER BY id ASC
    </select>
</mapper>
